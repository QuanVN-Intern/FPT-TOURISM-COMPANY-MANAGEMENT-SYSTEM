<UserControl x:Class="TOURISM_COMPANY_MANAGEMENT_SYSTEM.Views.VehicleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:TOURISM_COMPANY_MANAGEMENT_SYSTEM.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="#F5F7FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="White" CornerRadius="8"
                Padding="15" Margin="0, 0, 0, 15" BorderBrush="#E0E6ED" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="🚗 VEHICLE MANAGEMENT"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,15"/>
                <WrapPanel>
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Plate Number"/>
                        <TextBox x:Name="TxtSearchPlate"
                                 Width="200"
                                 Height="30"/>
                    </StackPanel>
                    <Button x:Name="btnSearch"
                            Content="Search"
                            Width="90"
                            Height="30"
                            Background="#3498DB"
                            Foreground="White"
                            Margin="0,15,10,10"
                            Click="BtnSearch_Click"/>
                    <Button x:Name="btnReset"
                            Content="Reset"
                            Width="90" Height="30" Background="#95A5A6"
                            Foreground="White" Margin="0,15,10,10"
                            Click="btnReset_Click"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="8"
                    Padding="10"
                    Margin="0,0,15,0"
                    BorderBrush="#E0E6ED"
                    BorderThickness="1">
                <DataGrid x:Name="dgVehicles"
                          AutoGenerateColumns="False"
                          SelectionMode="Single"
                          IsReadOnly="True"
                          SelectionChanged="dgVehicles_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Plate" Binding="{Binding PlateNumber}" Width="*"/>
                        <DataGridTextColumn Header="Capacity" Binding="{Binding Capacity}" Width="*"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                        <DataGridTextColumn Header="Note" Binding="{Binding Notes}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="8"
                    Padding="15"                 
                    BorderBrush="#E0E6ED"
                    BorderThickness="1">
                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="Vehicle Details"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>
                        <TextBox x:Name="txtId" Visibility="Collapsed"/>
                        <TextBlock Text="Plate Number"/>
                        <TextBox x:Name="txtPlate" Height="30" Margin="0,0,0,10"/>
                        <TextBlock Text="Capacity"/>
                        <ComboBox x:Name="CbCapacity" Height="30" Margin="0,0,0,10">
                            <ComboBoxItem Content="4"/>
                            <ComboBoxItem Content="7"/>
                            <ComboBoxItem Content="16"/>
                            <ComboBoxItem Content="45"/>
                        </ComboBox>
                        <TextBlock Text="Status"/>
                        <ComboBox x:Name="CbStatus"
                                  Height="30"
                                  Margin="0,0,0,10">
                            <ComboBoxItem Content="Available"/>
                            <ComboBoxItem Content="Busy"/>
                            <ComboBoxItem Content="Maintenance"/>

                        </ComboBox>
                        <TextBlock Text="Notes"/>
                        <TextBox x:Name="txtNote" Height="60" AcceptsReturn="True" Margin="0,0,0,20"/>
                        
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="BtnAdd" Grid.Column="0" Content="Add New" Height="38" Background="#2ECC71" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnAdd_Click"/>
                            <Button x:Name="BtnUpdate" Grid.Column="2" Content="Update" Height="38" Background="#F1C40F" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand" IsEnabled="False" Click="BtnUpdate_Click"/>
                        </Grid>

                        <Grid Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="BtnDelete" Grid.Column="0" Content="Delete" Height="35" Background="#E74C3C" Foreground="Black" BorderThickness="0" Cursor="Hand" IsEnabled="False" Click="BtnDelete_Click"/>
                            <Button x:Name="BtnClear" Grid.Column="2" Content="Clear Form" Height="35" Background="#BDC3C7" Foreground="Black" BorderThickness="0" Cursor="Hand" Click="BtnClear_Click"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
