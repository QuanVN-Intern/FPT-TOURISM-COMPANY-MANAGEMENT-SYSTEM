<Window x:Class="TOURISM_COMPANY_MANAGEMENT_SYSTEM.Views.AccountFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account Form"
        Height="400" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtTitle" Grid.Row="0"
                   FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <StackPanel x:Name="PanelUsername">
                <TextBlock Text="Username *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtUsername" Height="32" Padding="8,4"
                         Margin="0,0,0,12" BorderBrush="#BDC3C7" FontSize="13"/>
            </StackPanel>

            <StackPanel x:Name="PanelPassword">
                <TextBlock Text="Password *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <PasswordBox x:Name="TxtPassword" Height="32" Padding="8,4"
                             Margin="0,0,0,12" BorderBrush="#BDC3C7" FontSize="13"/>
            </StackPanel>

            <TextBlock Text="Full Name *" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtFullName" Height="32" Padding="8,4"
                     Margin="0,0,0,12" BorderBrush="#BDC3C7" FontSize="13"/>

            <TextBlock Text="Email *" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtEmail" Height="32" Padding="8,4"
                     Margin="0,0,0,12" BorderBrush="#BDC3C7" FontSize="13"/>

            <TextBlock Text="Role *" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbRole" Height="32" Margin="0,0,0,12"
                      DisplayMemberPath="RoleName" SelectedValuePath="RoleId"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Width="90" Height="34" Margin="0,0,10,0"
                    Background="#95A5A6" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="BtnCancel_Click"/>
            <Button Content="Save" Width="90" Height="34"
                    Background="#27AE60" Foreground="White" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>