<Window x:Class="TOURISM_COMPANY_MANAGEMENT_SYSTEM.Views.AccountFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account Form"
        Height="520" Width="460"
        MinHeight="520" MinWidth="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable form content -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="30,24,30,0">
            <StackPanel>

                <TextBlock x:Name="TxtTitle" FontSize="18" FontWeight="Bold"
                           Foreground="#2C3E50" Margin="0,0,0,20"/>

                <StackPanel x:Name="PanelUsername">
                    <TextBlock Text="Username *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtUsername" Height="34" Padding="8,6"
                             Margin="0,0,0,14" BorderBrush="#BDC3C7" FontSize="13"/>
                </StackPanel>

                <StackPanel x:Name="PanelPassword">
                    <TextBlock Text="Password *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="TxtPassword" Height="34" Padding="8,6"
                                 Margin="0,0,0,14" BorderBrush="#BDC3C7" FontSize="13"/>
                </StackPanel>

                <TextBlock Text="Full Name *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtFullName" Height="34" Padding="8,6"
                         Margin="0,0,0,14" BorderBrush="#BDC3C7" FontSize="13"/>

                <TextBlock Text="Email *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtEmail" Height="34" Padding="8,6"
                         Margin="0,0,0,14" BorderBrush="#BDC3C7" FontSize="13"/>

                <TextBlock Text="Date of Birth (must be 18+)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <DatePicker x:Name="DpDob" Height="34" Margin="0,0,0,14"
                            BorderBrush="#BDC3C7" FontSize="13"/>

                <TextBlock Text="Role *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox x:Name="CmbRole" Height="34" Margin="0,0,0,6"
                          DisplayMemberPath="RoleName" SelectedValuePath="RoleId"
                          FontSize="13"/>

                <TextBlock FontSize="11" Foreground="#E67E22" TextWrapping="Wrap"
                           Margin="0,4,0,14"
                           Text="Note: Admin role cannot be assigned. Only one Admin is allowed."/>

            </StackPanel>
        </ScrollViewer>

        <!-- Fixed bottom buttons -->
        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="30,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="90" Height="36" Margin="0,0,10,0"
                        Background="#95A5A6" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnCancel_Click"/>
                <Button Content="Save" Width="90" Height="36"
                        Background="#27AE60" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="BtnSave_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>