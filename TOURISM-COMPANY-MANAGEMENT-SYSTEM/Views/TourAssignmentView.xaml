<UserControl x:Class="TOURISM_COMPANY_MANAGEMENT_SYSTEM.Views.TourAssignmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded"
             Background="#F5F7FA">
    <TabControl Margin="15">

        <!-- ═══════════════════════════════════════════ -->
        <!-- TAB 1: Tour Guide → Schedule Assignment    -->
        <!-- ═══════════════════════════════════════════ -->
        <TabItem Header="Tour Guide Assignment">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Assign Tour Guides to Schedules"
                           FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>

                <Border Grid.Row="1" Background="White" BorderBrush="#DDE3EA"
                        BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,12">
                    <WrapPanel>
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Tour Schedule" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox x:Name="CbGuideSchedules" Width="220"
                                      DisplayMemberPath="DisplayText" SelectedValuePath="ScheduleId"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Tour Guide" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox x:Name="CbGuides" Width="200"
                                      DisplayMemberPath="FullName" SelectedValuePath="AccountId"/>
                        </StackPanel>
                        <Button Content="Assign Guide" VerticalAlignment="Bottom" Height="32"
                                Padding="14,0" Background="#27AE60" Foreground="White"
                                FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                Click="BtnAssignGuide_Click"/>
                    </WrapPanel>
                </Border>

                <Border Grid.Row="2" Background="White" BorderBrush="#DDE3EA"
                        BorderThickness="1" CornerRadius="6" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Current Guide Assignments" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                        <DataGrid x:Name="DgGuideAssignments" Grid.Row="1"
                                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tour Name"   Binding="{Binding TourName}"    Width="*"/>
                                <DataGridTextColumn Header="Departure"   Binding="{Binding DepartureText}" Width="110"/>
                                <DataGridTextColumn Header="Guide Name"  Binding="{Binding GuideName}"   Width="180"/>
                                <DataGridTemplateColumn Header="Action" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Remove" Background="#E74C3C" Foreground="White"
                                                    Cursor="Hand" Margin="2" Click="BtnRemoveGuide_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>

        <!-- ═══════════════════════════════════════════ -->
        <!-- TAB 2: Manage Tour Guides (CRUD)           -->
        <!-- ═══════════════════════════════════════════ -->
        <TabItem Header="Manage Tour Guides">
            <ContentControl x:Name="GuideMgmtContent"/>
        </TabItem>

        <!-- ═══════════════════════════════════════════ -->
        <!-- TAB 3: Driver → Vehicle Assignment         -->
        <!-- ═══════════════════════════════════════════ -->
        <TabItem Header="Driver &amp; Vehicle">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Assign Drivers to Vehicles"
                           FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>

                <Border Grid.Row="1" Background="White" BorderBrush="#DDE3EA"
                        BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,12">
                    <WrapPanel>
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Vehicle" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox x:Name="CbVehiclesForDriver" Width="180"
                                      DisplayMemberPath="PlateNumber" SelectedValuePath="VehicleId"
                                      SelectionChanged="CbVehiclesForDriver_SelectionChanged"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Current Driver" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtCurrentDriver" Width="180" IsReadOnly="True"
                                     Background="#ECF0F1" Height="30"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Assign Driver" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox x:Name="CbDriversForVehicle" Width="180"
                                      DisplayMemberPath="FullName" SelectedValuePath="AccountId"/>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Bottom">
                            <Button Content="Assign Driver" Height="30" Padding="12,0"
                                    Background="#2980B9" Foreground="White" FontWeight="Bold"
                                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                                    Click="BtnAssignDriverToVehicle_Click"/>
                            <Button Content="Remove Driver" Height="30" Padding="12,0"
                                    Background="#E67E22" Foreground="White" FontWeight="Bold"
                                    BorderThickness="0" Cursor="Hand" Margin="0,4,8,0"
                                    Click="BtnRemoveDriverFromVehicle_Click"/>
                        </StackPanel>
                    </WrapPanel>
                </Border>

                <Border Grid.Row="2" Background="White" BorderBrush="#DDE3EA"
                        BorderThickness="1" CornerRadius="6" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Vehicle — Driver Overview" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                        <DataGrid x:Name="DgVehicleDrivers" Grid.Row="1"
                                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Plate Number" Binding="{Binding PlateNumber}" Width="130"/>
                                <DataGridTextColumn Header="Capacity"     Binding="{Binding Capacity}"    Width="80"/>
                                <DataGridTextColumn Header="Status"       Binding="{Binding Status}"      Width="100"/>
                                <DataGridTextColumn Header="Assigned Driver" Binding="{Binding Driver.FullName}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>

        <!-- ═══════════════════════════════════════════ -->
        <!-- TAB 4: Manage Drivers                      -->
        <!-- ═══════════════════════════════════════════ -->
        <TabItem Header="Manage Drivers">
            <ContentControl x:Name="DriverMgmtContent"/>
        </TabItem>

    </TabControl>
</UserControl>
