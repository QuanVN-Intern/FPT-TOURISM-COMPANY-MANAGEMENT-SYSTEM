<UserControl x:Class="TOURISM_COMPANY_MANAGEMENT_SYSTEM.Views.TourAssignmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded">

    <TabControl Margin="10">
        <!-- Tab 1: Assignments -->
        <TabItem Header="Tour Assignments">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Tour Driver Assignment" FontSize="20"
                           FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>

                <!-- Selection Panel -->
                <Border Grid.Row="1" Background="#FDFDFD" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Tour" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ComboBox x:Name="CbTours" Width="200" DisplayMemberPath="TourName" SelectedValuePath="TourId"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Driver" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ComboBox x:Name="CbDrivers" Width="180" DisplayMemberPath="FullName" SelectedValuePath="AccountId"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Vehicle" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ComboBox x:Name="CbVehicles" Width="150" DisplayMemberPath="PlateNumber" SelectedValuePath="VehicleId"/>
                        </StackPanel>

                        <Button x:Name="BtnAssign" Content="Assign" VerticalAlignment="Bottom" Height="30" Width="100"
                                Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnAssign_Click"/>
                    </StackPanel>
                </Border>

                <!-- Current Assignments List -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Current Assignments" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10"/>
                    
                    <DataGrid x:Name="DgAssignments" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tour"    Binding="{Binding TourName}" Width="*"/>
                            <DataGridTextColumn Header="Driver"  Binding="{Binding DriverName}" Width="150"/>
                            <DataGridTextColumn Header="Vehicle" Binding="{Binding VehiclePlate}" Width="120"/>
                            <DataGridTemplateColumn Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Delete" Background="#E74C3C" Foreground="White" 
                                                Click="BtnDeleteAssignment_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </TabItem>

        <!-- Tab 2: Driver Management -->
        <TabItem Header="Manage Drivers">
            <ContentControl x:Name="DriverMgmtContent"/>
        </TabItem>
    </TabControl>
</UserControl>
