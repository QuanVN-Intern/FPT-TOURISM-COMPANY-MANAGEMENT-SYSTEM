<UserControl x:Class="TOURISM_COMPANY_MANAGEMENT_SYSTEM.Views.DriverManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Driver Management" FontSize="22"
                   FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,14"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="BtnRefresh" Content="Refresh" Width="100" Height="34"
                    Background="#3498DB" Foreground="White" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0" Click="BtnRefresh_Click"/>
            <Button x:Name="BtnToggleActive" Content="Toggle Active" Width="120" Height="34"
                    Background="#E67E22" Foreground="White" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="BtnToggleActive_Click"/>
        </StackPanel>

        <DataGrid x:Name="DgDrivers" Grid.Row="2"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" AlternatingRowBackground="#F9F9F9"
                  BorderBrush="#E0E0E0" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"          Binding="{Binding AccountId}" Width="50"/>
                <DataGridTextColumn Header="Full Name"   Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="License No"  Binding="{Binding LicenseNumber}" Width="150"/>
                <DataGridTextColumn Header="Email"       Binding="{Binding Email}" Width="180"/>
                <DataGridCheckBoxColumn Header="Active"  Binding="{Binding IsActive}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
