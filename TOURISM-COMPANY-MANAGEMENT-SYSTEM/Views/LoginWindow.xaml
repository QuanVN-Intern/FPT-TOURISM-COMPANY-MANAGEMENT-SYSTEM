<Window x:Class="TOURISM_COMPANY_MANAGEMENT_SYSTEM.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FPT Tourism — Login"
        Height="460" Width="460"
        MinHeight="420" MinWidth="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F0F4F8">
        <Grid MinHeight="420">
            <Border Background="White" CornerRadius="10" Margin="40,30">
                <StackPanel Margin="36,30">

                    <TextBlock Text="FPT Tourism" FontSize="26" FontWeight="Bold"
                               Foreground="#2C3E50" HorizontalAlignment="Center"/>
                    <TextBlock Text="Management System" FontSize="13" Foreground="#7F8C8D"
                               HorizontalAlignment="Center" Margin="0,2,0,28"/>

                    <TextBlock Text="Username" FontWeight="SemiBold"
                               Foreground="#2C3E50" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtUsername" Height="38" Padding="10,8"
                             FontSize="14" BorderBrush="#BDC3C7" BorderThickness="1"
                             KeyDown="Input_KeyDown"/>

                    <TextBlock Text="Password" FontWeight="SemiBold"
                               Foreground="#2C3E50" Margin="0,16,0,4"/>
                    <PasswordBox x:Name="TxtPassword" Height="38" Padding="10,8"
                                 FontSize="14" BorderBrush="#BDC3C7" BorderThickness="1"
                                 KeyDown="Input_KeyDown"/>

                    <TextBlock x:Name="TxtError" Foreground="#E74C3C" FontSize="12"
                               Margin="0,10,0,0" TextWrapping="Wrap"
                               Visibility="Collapsed"/>

                    <Button Content="Login" Height="42" Margin="0,22,0,10"
                            Background="#2C3E50" Foreground="White"
                            FontSize="15" FontWeight="Bold" BorderThickness="0"
                            Cursor="Hand" Click="BtnLogin_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#2C3E50"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6" Padding="0,8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3D5A73"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>