<UserControl x:Class="TOURISM_COMPANY_MANAGEMENT_SYSTEM.Views.AccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Account Management" FontSize="22"
                   FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,14"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="BtnAdd"    Content="+ Add Account"   Width="120" Height="34"
                    Background="#27AE60" Foreground="White" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0" Click="BtnAdd_Click"/>
            <Button x:Name="BtnEdit"   Content="Edit"            Width="80"  Height="34"
                    Background="#2980B9" Foreground="White" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0" Click="BtnEdit_Click"/>
            <Button x:Name="BtnToggle" Content="Enable/Disable"  Width="130" Height="34"
                    Background="#E67E22" Foreground="White" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0" Click="BtnToggle_Click"/>
            <Button x:Name="BtnReset"  Content="Reset Password"  Width="130" Height="34"
                    Background="#8E44AD" Foreground="White" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0" Click="BtnReset_Click"/>
            <Button x:Name="BtnDelete" Content="Delete"          Width="90"  Height="34"
                    Background="#E74C3C" Foreground="White" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="BtnDelete_Click"/>
        </StackPanel>

        <DataGrid x:Name="DgAccounts" Grid.Row="2"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" AlternatingRowBackground="#F9F9F9"
                  BorderBrush="#E0E0E0" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"        Binding="{Binding AccountId}" Width="50"/>
                <DataGridTextColumn Header="Username"  Binding="{Binding Username}"  Width="120"/>
                <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}"  Width="*"/>
                <DataGridTextColumn Header="Email"     Binding="{Binding Email}"     Width="180"/>
                <DataGridTextColumn Header="Role"      Binding="{Binding RoleName}"  Width="110"/>
                <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>