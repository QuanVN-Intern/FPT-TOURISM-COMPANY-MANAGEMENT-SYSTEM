<Window x:Class="TOURISM_COMPANY_MANAGEMENT_SYSTEM.Views.PasswordResetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset Password"
        Height="260" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtTitle" Grid.Row="0"
                   FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="New Password *" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <PasswordBox x:Name="TxtNew" Height="32" Padding="8,4"
                         Margin="0,0,0,12" BorderBrush="#BDC3C7" FontSize="13"/>

            <TextBlock Text="Confirm Password *" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <PasswordBox x:Name="TxtConfirm" Height="32" Padding="8,4"
                         BorderBrush="#BDC3C7" FontSize="13"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Width="90" Height="34" Margin="0,0,10,0"
                    Background="#95A5A6" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="BtnCancel_Click"/>
            <Button Content="Reset" Width="90" Height="34"
                    Background="#8E44AD" Foreground="White" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="BtnReset_Click"/>
        </StackPanel>
    </Grid>
</Window>