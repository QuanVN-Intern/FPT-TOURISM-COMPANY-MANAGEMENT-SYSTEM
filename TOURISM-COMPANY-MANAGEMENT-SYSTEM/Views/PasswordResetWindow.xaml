<Window x:Class="TOURISM_COMPANY_MANAGEMENT_SYSTEM.Views.PasswordResetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset Password"
        Height="300" Width="400"
        MinHeight="280" MinWidth="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="30,24,30,0">
            <StackPanel>
                <TextBlock x:Name="TxtTitle" FontSize="15" FontWeight="Bold"
                           Foreground="#2C3E50" Margin="0,0,0,20" TextWrapping="Wrap"/>

                <TextBlock Text="New Password *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <PasswordBox x:Name="TxtNew" Height="34" Padding="8,6"
                             Margin="0,0,0,14" BorderBrush="#BDC3C7" FontSize="13"/>

                <TextBlock Text="Confirm Password *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <PasswordBox x:Name="TxtConfirm" Height="34" Padding="8,6"
                             BorderBrush="#BDC3C7" FontSize="13"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="30,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="90" Height="36" Margin="0,0,10,0"
                        Background="#95A5A6" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnCancel_Click"/>
                <Button Content="Reset" Width="90" Height="36"
                        Background="#8E44AD" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="BtnReset_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>