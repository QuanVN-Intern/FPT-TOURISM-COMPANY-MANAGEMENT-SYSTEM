<Window x:Class="TOURISM_COMPANY_MANAGEMENT_SYSTEM.Views.CustomerFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer Form"
        Height="580" Width="500"
        MinHeight="500" MinWidth="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="30,24,30,0">
            <StackPanel>

                <TextBlock x:Name="TxtTitle" FontSize="18" FontWeight="Bold"
                           Foreground="#2C3E50" Margin="0,0,0,20"/>

                <TextBlock Text="Full Name *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtFullName" Height="34" Padding="8,6"
                         Margin="0,0,0,14" BorderBrush="#BDC3C7" FontSize="13"/>

                <TextBlock Text="Phone *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtPhone" Height="34" Padding="8,6"
                         Margin="0,0,0,14" BorderBrush="#BDC3C7" FontSize="13"/>

                <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtEmail" Height="34" Padding="8,6"
                         Margin="0,0,0,14" BorderBrush="#BDC3C7" FontSize="13"/>

                <TextBlock Text="Date of Birth" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <DatePicker x:Name="DpDob" Height="34" Margin="0,0,0,14"
                            BorderBrush="#BDC3C7" FontSize="13"/>

                <TextBlock Text="Address" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtAddress" Height="34" Padding="8,6"
                         Margin="0,0,0,14" BorderBrush="#BDC3C7" FontSize="13"/>

                <TextBlock Text="Passport No" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtPassport" Height="34" Padding="8,6"
                         Margin="0,0,0,14" BorderBrush="#BDC3C7" FontSize="13"/>

                <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtNotes" Height="70" Padding="8,6"
                         Margin="0,0,0,14" BorderBrush="#BDC3C7" FontSize="13"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Fixed bottom buttons — always visible -->
        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="30,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="90" Height="36" Margin="0,0,10,0"
                        Background="#95A5A6" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnCancel_Click"/>
                <Button Content="Save" Width="90" Height="36"
                        Background="#27AE60" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="BtnSave_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>