<Window x:Class="TOURISM_COMPANY_MANAGEMENT_SYSTEM.Views.CustomerFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer Form"
        Height="520" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtTitle" Grid.Row="0"
                   FontSize="18" FontWeight="Bold" Foreground="#2C3E50"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Full Name *" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtFullName" Height="32" Padding="8,4" Margin="0,0,0,12"
                     BorderBrush="#BDC3C7" FontSize="13"/>

            <TextBlock Text="Phone *" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtPhone" Height="32" Padding="8,4" Margin="0,0,0,12"
                     BorderBrush="#BDC3C7" FontSize="13"/>

            <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtEmail" Height="32" Padding="8,4" Margin="0,0,0,12"
                     BorderBrush="#BDC3C7" FontSize="13"/>

            <TextBlock Text="Date of Birth" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <DatePicker x:Name="DpDob" Height="32" Margin="0,0,0,12"
                        BorderBrush="#BDC3C7" FontSize="13"/>

            <TextBlock Text="Address" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtAddress" Height="32" Padding="8,4" Margin="0,0,0,12"
                     BorderBrush="#BDC3C7" FontSize="13"/>

            <TextBlock Text="Passport No" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtPassport" Height="32" Padding="8,4" Margin="0,0,0,12"
                     BorderBrush="#BDC3C7" FontSize="13"/>

            <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtNotes" Height="56" Padding="8,4"
                     BorderBrush="#BDC3C7" FontSize="13"
                     TextWrapping="Wrap" AcceptsReturn="True"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Width="90" Height="34" Margin="0,0,10,0"
                    Background="#95A5A6" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="BtnCancel_Click"/>
            <Button Content="Save" Width="90" Height="34"
                    Background="#27AE60" Foreground="White" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>