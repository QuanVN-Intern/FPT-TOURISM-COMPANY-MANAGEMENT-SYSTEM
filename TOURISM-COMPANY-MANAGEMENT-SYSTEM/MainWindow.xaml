<Window x:Class="TOURISM_COMPANY_MANAGEMENT_SYSTEM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="FPT Tourism Management System"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Nav Bar -->
        <Grid Grid.Row="0" Background="#1E293B">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">

                <ComboBox x:Name="CbManagement" Width="126" Margin="8,10,0,10"
                          Background="Gray" Foreground="White" FontWeight="Bold"
                          VerticalContentAlignment="Center" Padding="10,0"
                          SelectionChanged="CbManagement_SelectionChanged"
                          Style="{StaticResource {x:Static ToolBar.ComboBoxStyleKey}}" Height="40">
                    <ComboBoxItem x:Name="CbiPlaceholder" Content="Management" Visibility="Collapsed"/>
                    <ComboBoxItem x:Name="CbiTours"     Content="Tours"/>
                    <ComboBoxItem x:Name="CbiVehicles"  Content="Vehicles"/>
                    <ComboBoxItem x:Name="CbiCustomers" Content="Customers"/>
                    <ComboBoxItem x:Name="CbiAccounts"  Content="Accounts"/>
                </ComboBox>

                <Button x:Name="BtnOpenBooking" Content="Bookings" Width="120" Margin="8,10,0,10"
                        Background="#F59E0B" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="BtnOpenBooking_Click"/>

                <Button x:Name="BtnOpenAssignment" Content="Assignments" Width="120" Margin="8,10,0,10"
                        Background="#6366F1" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="BtnOpenAssignment_Click"/>

                <Button x:Name="BtnOpenPayment" Content="Payments" Width="120" Margin="8,10,0,10"
                        Background="#2980B9" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="BtnOpenPayment_Click"/>

                <Button x:Name="BtnOpenStatistics" Content="Statistics" Width="120" Margin="8,10,0,10"
                        Background="#10B981" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="BtnOpenStatistics_Click"/>

            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,16,0">
                <TextBlock x:Name="TxtCurrentUser" Foreground="#BDC3C7"
                           FontSize="13" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <Button Content="Logout" Width="80" Height="32"
                        Background="#E74C3C" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="BtnLogout_Click"/>
            </StackPanel>
        </Grid>

        <ContentControl x:Name="MainContent" Grid.Row="1"/>
    </Grid>
</Window>