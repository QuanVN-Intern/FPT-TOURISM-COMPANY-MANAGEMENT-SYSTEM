<Window x:Class="TOURISM_COMPANY_MANAGEMENT_SYSTEM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="FPT Tourism Management System"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#2C3E50">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="Tours"     Width="130" Margin="15,10,0,10"
                        Background="#3498DB" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="BtnOpenTour_Click"/>
                <Button Content="Customers" Width="130" Margin="8,10,0,10"
                        Background="#27AE60" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="BtnOpenCustomer_Click"/>
                <Button Content="Vehicles" Width="130" Margin="8,10,0,10"
                        Background="#F39C12" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="BtnOpenVehicle_Click"/>
                <Button Content="Bookings" Width="130" Margin="8,10,0,10"
                        Background="#D35400" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="BtnOpenBooking_Click"/>
                <Button x:Name="BtnOpenAccount" Content="Accounts" Width="130" Margin="8,10,0,10"
                        Background="#8E44AD" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="BtnOpenAccount_Click"/>
                <Button Content="Assignments" Width="130" Margin="8,10,0,10"
                        Background="#2C3E50" Foreground="White" FontWeight="Bold"
                        BorderThickness="1" BorderBrush="#7F8C8D" Cursor="Hand" Click="BtnOpenAssignment_Click"/>
                <Button Content="Statistics" Width="130" Margin="8,10,0,10"
                        Background="#16A085" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="BtnOpenStatistics_Click"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,16,0">
                <TextBlock x:Name="TxtCurrentUser" Foreground="#BDC3C7"
                           FontSize="13" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <Button Content="Logout" Width="80" Height="32"
                        Background="#E74C3C" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="BtnLogout_Click"/>
            </StackPanel>
        </Grid>

        <ContentControl x:Name="MainContent" Grid.Row="1"/>
    </Grid>
</Window>
