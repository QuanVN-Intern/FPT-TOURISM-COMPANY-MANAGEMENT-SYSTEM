<Window x:Class="TOURISM_COMPANY_MANAGEMENT_SYSTEM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TOURISM_COMPANY_MANAGEMENT_SYSTEM"
        mc:Ignorable="d"
        Title="Tourism Management System" Height="800" Width="1200" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header / Navigation Bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#2C3E50">
            <Button Content="Manage Tours" Width="150" Margin="15,10" Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnOpenTour_Click"/>
            <Button Content="Manage Bookings" Width="150" Margin="5,10" Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnOpenBooking_Click"/>
            <Button Content="Manage Vehicles" Width="150" Margin="5,10" Background="#F39C12" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnOpenVehicle_Click"/>
        </StackPanel>

        <!-- Main Workspace -->
        <ContentControl x:Name="MainContent" Grid.Row="1"/>
    </Grid>
</Window>
